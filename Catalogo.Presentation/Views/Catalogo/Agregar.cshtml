@model CatalogoApp.Domain.Models.Item

@{
    ViewData["Title"] = "Agregar Videojuego";
}

<div class="container mt-5">

    <div class="card mx-auto p-4"
         style="max-width: 650px;">

        <div class="card-body">

            <h1 class="text-center mb-4">
                🎮 Agregar Videojuego
            </h1>

            <form asp-action="Agregar" method="post">

                <div class="mb-3">
                    <label class="form-label">Título</label>
                    <input asp-for="Titulo"
                           class="form-control"
                           placeholder="Ej. The Legend of Zelda" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Género</label>
                    <input asp-for="Genero"
                           class="form-control"
                           placeholder="Ej. Aventura, Acción, RPG" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Consola</label>
                    <input asp-for="Consola"
                           class="form-control"
                           placeholder="Ej. Nintendo Switch, Xbox, PlayStation" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Año</label>
                    <input asp-for="Ano"
                           class="form-control"
                           placeholder="Ej. 2024" />
                </div>

                <div class="mb-4">
                    <label class="form-label">Descripción</label>
                    <textarea asp-for="Descripcion"
                              class="form-control"
                              rows="4"
                              placeholder="Escribe una pequeña descripción del videojuego"></textarea>
                </div>

                <div class="d-flex gap-3">

                    <button type="submit"
                            class="btn btn-success w-50">
                        Guardar
                    </button>

                    <a asp-action="Index"
                       class="btn btn-outline-info w-50">
                        Cancelar
                    </a>

                </div>

            </form>

        </div>

    </div>

</div>