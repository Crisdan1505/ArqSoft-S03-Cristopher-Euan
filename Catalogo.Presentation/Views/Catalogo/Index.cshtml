@using Microsoft.AspNetCore.Http
@model List<CatalogoApp.Domain.Models.Item>

@{
    ViewData["Title"] = "Mi Catálogo";
}

<div class="catalogo-hero mb-5">

    <div class="hero-icon">
        🎮
    </div>

    <div>
        <h1 class="catalogo-title">
            Mi Catálogo Gamer
        </h1>

        <p class="catalogo-subtitle">
            Explora, administra y califica tu colección de videojuegos favoritos
        </p>
    </div>

</div>

    <div class="mb-4 p-3 rounded border border-info bg-dark">

        <span class="text-info fw-bold me-3">
            Géneros:
        </span>

        <a class="btn btn-outline-info btn-sm me-2 mb-2"
           asp-action="Index">
            Todos
        </a>

        @foreach (var gen in ViewBag.Generos as List<string>)
        {
            <a class="btn btn-outline-primary btn-sm me-2 mb-2"
               asp-action="Index"
               asp-route-genero="@gen">
                @gen
            </a>
        }

    </div>

    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">

                <div class="card h-100 bg-dark border-info shadow">

                    <div class="card-body">

                        <h4 class="card-title text-info">
                            @item.Titulo
                        </h4>

                        <hr class="border-info" />

                        <p class="card-text text-light">
                            <strong>Género:</strong> @item.Genero
                        </p>

                        <p class="card-text text-light">
                            <strong>Año:</strong> @item.Ano
                        </p>

                        <hr class="border-info" />

                        @if (Context.Session.GetString("Usuario") != null)
                        {
                            <form method="post" asp-action="Calificar">

                                <input type="hidden" name="videojuego" value="@item.Titulo" />

                                <div class="mb-2">
                                    <label class="text-light">Puntuación</label>
                                    <select name="puntuacion" class="form-control">
                                        <option value="0">0 estrellas</option>
                                        <option value="1">1 estrella ⭐</option>
                                        <option value="2">2 estrellas ⭐⭐</option>
                                        <option value="3">3 estrellas ⭐⭐⭐</option>
                                        <option value="4">4 estrellas ⭐⭐⭐⭐</option>
                                        <option value="5">5 estrellas ⭐⭐⭐⭐⭐</option>
                                    </select>
                                </div>

                                <div class="mb-2">
                                    <label class="text-light">Comentario</label>
                                    <textarea name="comentario"
                                              class="form-control"
                                              rows="2"></textarea>
                                </div>

                                <button type="submit" class="btn btn-warning w-100">
                                    Enviar calificación
                                </button>

                            </form>
                        }
                        else
                        {
                            <a class="btn btn-outline-warning w-100"
                               asp-controller="Auth"
                               asp-action="Login">
                                Inicia sesión para calificar
                            </a>
                        }

                    </div>

                    <div class="card-footer bg-transparent border-info">

                        <a class="btn btn-primary w-100"
                           asp-action="Detalle"
                           asp-route-id="@item.Id">
                            Ver Detalles
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

@if (ViewBag.Calificaciones != null && ViewBag.Calificaciones.Count > 0)
{
    <div class="mt-5">

        <h2 class="text-warning mb-4">
            ⭐ Reseñas de la comunidad
        </h2>

        @foreach (var calificacion in ViewBag.Calificaciones)
        {
            <div class="card bg-dark border-warning text-light mt-3 mb-4 shadow">

                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center mb-3">

                        <h4 class="text-warning">
                            🎮 @calificacion.Videojuego
                        </h4>

                        <span class="badge bg-warning text-dark fs-6">
                            @calificacion.Puntuacion / 5 ⭐
                        </span>

                    </div>

                    <p class="mb-0">
                        <strong>Comentario:</strong>
                        @calificacion.Comentario
                    </p>

                </div>

            </div>
        }

    </div>
}

    <div class="mt-4 mb-5">

        <a class="btn btn-success btn-lg"
           asp-action="Agregar">
            + Agregar Videojuego
        </a>

    </div>

